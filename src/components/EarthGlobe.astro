---
// 3D Rotating Earth ASCII - Basado en algoritmo de https://github.com/codegiovanni/3D_ASCII_Earth
---

<pre id="earthDisplay"></pre>

<script is:inline>
  const earthMap = `............................................................................................................................................
............................................................................................................................................
..................................+++++++..+++++++++++++++++++..............................................................................
......................+.+++++..+.+.+++++........++++++++++++++.............................+..........++++++++++++++..+.....++..............
......++++++++++++++++++++++++++++++++..++++.....++++++++++.................++++++++.....+++++++++++++++++++++++++++++++++++++++++++++++++++
......+++++++++++++++++++++++++++++.....++++......++++...................++++.+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++.
........++.......+++++++++++++++++......++++++......................+....++++..++++++++++++++++++++++++++++++++++++++++++++++......++.......
....................++++++++++++++++++.+++++++++....................++..++++++++++++++++++++++++++++++++++++++++++++++++++++.......+........
......................+++++++++++++++++++++++........................+++++++++++++++++++++++++++++++++++++++++++++++++++++++................
......................+++++++++++++++++++++........................++++...+.+++++....++++.+++++++++++++++++++++++++++++++...................
......................+++++++++++++++++++..........................+++........+..++++++++..+++++++++++++++++++++++++...+....+...............
.........................++++++++++++++............................+++++++++..+....++++++++++++++++++++++++++++++++++.......................
..........................++++++......+..........................++++++++++++++++++++++++++++++++++++++++++++++++++++.......................
.............................+++................................++++++++++++++++++++.++++++++....+++++++++++++++++..........................
...............................++.++............................+++++++++++++++++++++.+++++.......++++.....+++++............................
....................................++..........................+++++++++++++++++++++++++..........++.......+.++............................
........................................+++++++..................++++++++++++++++++++++++...................................................
.......................................+++++++++++........................++++++++++++++.....................+...+++........................
.......................................++++++++++++++++...................++++++++++++.......................++..++........++...............
.......................................+++++++++++++++++...................++++++++++.......................................++..............
........................................+++++++++++++++....................+++++++++++..................................+++..+..............
..........................................+++++++++++++....................+++++++++...++............................++++++++++.............
...........................................+++++++++........................++++++++...+..........................+++++++++++++++...........
..........................................+++++++++.........................++++++................................+++++++++++++++...........
..........................................+++++++............................+++...................................+++....+++++++...........
..........................................++++................................................................................+.............
.........................................++++...............................................................................................
.........................................+++................................................................................................
............................................................................................................................................
............................................................................................................................................
............................................................................................................................................
............................................++.....................................+.++++++++++++..+++++++++++++++++++++++++++++++++........
....................+++++++...++++++++++++++++.................+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++......
..........+++++++++++++++++++++++++++++++..........+....+++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++......."`;

  const lines = earthMap.split('\n');
  const mapWidth = lines[0].length;
  const mapHeight = lines.length;
  const sphereRadius = 8;
  
  // Precalcular seno y coseno para optimización
  const sin = new Float32Array(1000);
  const cos = new Float32Array(1000);
  for (let i = 0; i < 1000; i++) {
    const angle = i * 0.006283185307179; // 2π/1000
    sin[i] = Math.sin(angle);
    cos[i] = Math.cos(angle);
  }
  
  const screenWidth = 140;
  const screenHeight = 35;
  const display = document.getElementById('earthDisplay');
  
  let aA = 0; // Ángulo de rotación
  
  function renderFrame() {
    const output = new Array(screenWidth * screenHeight).fill(' ');
    
    let aY = 0;
    while (aY < 6.28) {
      let aX = 0;
      while (aX < 6.28) {
        // Calcular coordenadas 3D de la esfera
        const sinAY = sin[Math.floor((aY % 6.28) * 159.15) % 1000];
        const cosAY = cos[Math.floor((aY % 6.28) * 159.15) % 1000];
        const sinAX = sin[Math.floor((aX % 6.28) * 159.15) % 1000];
        const cosAX = cos[Math.floor((aX % 6.28) * 159.15) % 1000];
        
        let x = sphereRadius * sinAY * cosAX;
        let y = sphereRadius * sinAY * sinAX;
        let z = sphereRadius * cosAY;
        
        // Mapear contra el mapa de la tierra
        const SaX = Math.atan2(x, z);
        const SaY = Math.atan2(-y, Math.sqrt(x * x + z * z));
        
        const Co = Math.floor(((SaX / (2 * Math.PI) + 0.5) * mapWidth));
        const Ro = Math.floor((((SaY / Math.PI) + 0.5) * mapHeight));
        
        let char = ' ';
        if (Ro >= 0 && Ro < mapHeight && Co >= 0 && Co < mapWidth) {
          char = lines[Ro][Co % mapWidth] || ' ';
        }
        
        // Rotación en eje X
        const sinAA = sin[Math.floor((aA % 6.28) * 159.15) % 1000];
        const cosAA = cos[Math.floor((aA % 6.28) * 159.15) % 1000];
        
        const xRX = x * cosAA + z * sinAA;
        const zRX = -x * sinAA + z * cosAA;
        
        x = xRX;
        z = zRX;
        
        // Proyección perspectiva
        const iD = 1 / 10;
        const sX = Math.floor(screenWidth / 2 + 30 * iD * x);
        const sY = Math.floor(screenHeight / 2 - 15 * iD * y);
        
        // Solo renderizar si está visible (z > 0)
        if (z > 0 && sX >= 0 && sX < screenWidth && sY >= 0 && sY < screenHeight) {
          output[sX + screenWidth * sY] = char;
        }
        
        aX += 0.065;
      }
      aY += 0.065;
    }
    
    aA += 0.01; // Incrementar ángulo de rotación
    
    if (display) {
      display.textContent = '';
      for (let y = 0; y < screenHeight; y++) {
        for (let x = 0; x < screenWidth; x++) {
          display.textContent += output[x + screenWidth * y];
        }
        display.textContent += '\n';
      }
    }
  }
  
  // Animar
  setInterval(renderFrame, 150);
</script>

<style>
#earthDisplay {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: 'Consolas', 'Monaco', monospace;
  font-size: 5px;
  line-height: 1;
  white-space: pre;
  color: rgba(59, 130, 246, 0.25);
  text-shadow: 0 0 5px rgba(59, 130, 246, 0.3);
  z-index: -1;
  pointer-events: none;
  margin: 0;
  padding: 0;
  letter-spacing: 0px;
}
</style>

