---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0,SITE.NUM_PROJECTS_ON_HOMEPAGE);

---


<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-16">
      <section>
        <div class="flex flex-col gap-8">
          <article class="space-y-6">
            <div class="space-y-3">
              <h2 class="text-2xl font-bold animate text-black dark:text-white">
                Guillermo España Jiménez
              </h2>
              <p class="opacity-50 animate">
                Software Engineer | Madrid, Spain
              </p>
            </div>
  
            <p class="animate">
            I'm fascinated by the deep structures that organize complexity. I believe that 
            great engineering comes from understanding not just how systems work, but why they matter. 
            I'm passionate about computer science as a lens for understanding the world, 
            from the architecture of our machines to the philosophy behind the decisions we encode into code. 
            I write about the intersection of technology, design and the human experience.
            </p>
            <blockquote class="border-l-4 border-gray-300 dark:border-gray-600 pl-4 italic opacity-80 animate">
              The systems we build reflect who we are.
            </blockquote>
          </article>
        </div>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent Articles
          </h5>
          <Link href="/blog">
            View all
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {blog.map(post => (
            <li>
              <ArrowCard entry={post} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent Projects
          </h5>
          <Link href="/projects">
            View all
          </Link>
        </div>
        <ul class="animate flex flex-col gap-4">
          {projects.map((project) => (
            <li class="animate">
              <ArrowCard entry={project}/>
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Get in Touch
        </h5>
        <article>
          <p>
            I'm open to opportunities, collaborations and conversations about software engineering
            and open source projects. Feel free to reach out!
          </p>
        </article>
        <div class="mt-2">
          <button 
            id="i-was-here-button"
            class="relative group w-fit flex pl-3 pr-3 py-1.5 flex-nowrap rounded border border-black/15 dark:border-white/20 hover:bg-black/5 dark:hover:bg-white/5 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out items-center gap-2"
          >
            <span id="visitor-count" class="text-sm opacity-60"></span>
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              viewBox="0 0 24 24"
              class="size-4 fill-current group-hover:scale-110 transition-transform duration-300 ease-in-out">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
            <div class="text-sm">
              Say hi!
            </div>
          </button>
        </div>
        <ul class="flex flex-wrap gap-3">
          {SOCIALS.map(SOCIAL => (
            <li>
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME === 'email' ? SITE.EMAIL : SOCIAL.NAME}
              </Link>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
