    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // @ts-nocheck
      function initSphereTracking() {
        const projection = document.querySelector('.sphere-projection');
        if (!projection) return;
        
        let mouseX = window.innerWidth / 2;
        let mouseY = window.innerHeight / 2;
        
        function updateProjection() {
          const x = (mouseX / window.innerWidth) * 100;
          const y = (mouseY / window.innerHeight) * 100;
          projection.style.background = `radial-gradient(circle at ${x}% ${y}%, rgba(34, 197, 94, 0.15) 0%, rgba(34, 197, 94, 0.05) 30%, transparent 70%)`;
        }
        
        // Tracking del ratón - siempre activo con capture phase
        const handleMouseMove = (e) => {
          mouseX = e.clientX;
          mouseY = e.clientY;
          updateProjection();
        };
        
        // Reiniciar tracking después de cada click
        const handleClick = () => {
          updateProjection();
        };
        
        // Actualizar si cambia el tamaño de la ventana
        const handleResize = () => {
          updateProjection();
        };
        
        document.addEventListener('mousemove', handleMouseMove, true);
        document.addEventListener('click', handleClick, true);
        window.addEventListener('resize', handleResize);
        
        // Inicializar
        updateProjection();
        
        // Limpiar listeners anteriores antes de reinicializar
        return () => {
          document.removeEventListener('mousemove', handleMouseMove, true);
          document.removeEventListener('click', handleClick, true);
          window.removeEventListener('resize', handleResize);
        };
      }
      
      // Inicializar en carga
      let cleanup = initSphereTracking();
      
      // Función para inicializar el toggle de estrellas
      function initStarToggle() {
        const starToggle = document.querySelector('#sphere-effect');
        const animatedBackground = document.querySelector('.animated-background');
        
        if (!starToggle || !animatedBackground) return;
        
        // Recuperar estado guardado (por defecto visibles = true)
        const starsVisible = localStorage.getItem('starsVisible') !== 'false';
        if (!starsVisible) {
          animatedBackground.style.display = 'none';
        }
        
        // Manejar clicks en el botón
        const handleToggleClick = () => {
          const isVisible = animatedBackground.style.display !== 'none';
          animatedBackground.style.display = isVisible ? 'none' : '';
          localStorage.setItem('starsVisible', String(!isVisible));
          starToggle.classList.toggle('active');
        };
        
        // Si las estrellas están visibles, añadir clase active al botón
        if (starsVisible) {
          starToggle.classList.add('active');
        }
        
        starToggle.removeEventListener('click', handleToggleClick);
        starToggle.addEventListener('click', handleToggleClick);
        
        return handleToggleClick;
      }
      
      // Inicializar toggle en carga
      let toggleHandler = initStarToggle();
      
      // Reinicializar después de cambios de página (Astro View Transitions)
      document.addEventListener('astro:after-swap', () => {
        if (cleanup) cleanup();
        cleanup = initSphereTracking();
        toggleHandler = initStarToggle();
      });
    </script>
  </body>
</html>
